---
interface Props {
  icon: string;
  name: string;
}

const { icon, name } = Astro.props;
---

<div class="group relative flex flex-col items-center justify-center p-8 rounded-2xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.05] transition-all duration-300 hover:scale-[1.02] hover:border-white/10 overflow-hidden">
  {/* Glow Effect */}
  <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  
  <div class="relative z-10 w-12 h-12 mb-4 text-text-secondary group-hover:text-accent-glow transition-colors duration-300 flex items-center justify-center">
    <div class="tech-icon-svg w-full h-full" set:html={icon} />
  </div>
  
  <h3 class="relative z-10 text-sm font-medium text-text-secondary group-hover:text-text-primary transition-colors duration-300">
    {name}
  </h3>
</div>

<style>
  .tech-icon-svg :global(svg) {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
</style>
