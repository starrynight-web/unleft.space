---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import CookieBanner from "@/components/layout/CookieBanner";
import { EtheralShadow } from "@/components/ui/EtheralShadow";
import { SplashScreen } from "@/components/ui/SplashScreen";

// @fontsource imports - Localized fonts
import "@fontsource/bruno-ace-sc/index.css";
import "@fontsource/gupter/400.css";
import "@fontsource/gupter/700.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/jetbrains-mono/400.css";

import { SEO } from "astro-seo";

type StructuredData =
  | Record<string, unknown>
  | Array<Record<string, unknown>>;

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  imageAlt?: string;
  ogType?: "website" | "article";
  locale?: string;
  lang?: string;
  structuredData?: StructuredData;
  noindex?: boolean;
  nofollow?: boolean;
  showSplash?: boolean;
}

const BRAND_TITLE = "UNLEFT-Engineering The Future, Beyond Software.";
const DEFAULT_DESCRIPTION = "Engineering the Future. Beyond Software.";
const DEFAULT_IMAGE = "/assets/images/og-image.png";
const DEFAULT_IMAGE_ALT = "Unleft website preview";

const {
  title,
  description = DEFAULT_DESCRIPTION,
  keywords,
  image = DEFAULT_IMAGE,
  imageAlt = DEFAULT_IMAGE_ALT,
  ogType = "website",
  locale = "en_US",
  lang = "en",
  structuredData,
  noindex = false,
  nofollow = false,
  showSplash = false,
} = Astro.props;

const siteBase = Astro.site ?? new URL("https://www.unleft.space");
const canonicalURL = new URL(Astro.url.pathname, siteBase).toString();
const ogImageURL = new URL(image, siteBase).toString();

const fullTitle =
  Astro.url.pathname === "/" || title === "Home"
    ? BRAND_TITLE
    : title.includes(BRAND_TITLE)
      ? title
      : `${title} | ${BRAND_TITLE}`;

const breadcrumbLabelMap: Record<string, string> = {
  about: "About Us",
  contact: "Contact",
  cookies: "Cookie Policy",
  checkout: "Checkout",
  legal: "Legal",
  pricing: "Pricing",
  privacy: "Privacy Policy",
  projects: "Projects",
  services: "Services",
  tech: "Tech Stack",
  terms: "Terms & Conditions",
};

function titleizeSegment(segment: string) {
  return segment
    .split("-")
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}

function buildBreadcrumbStructuredData(pathname: string) {
  if (noindex || pathname === "/") return null;

  const trimmedPath = pathname.replace(/^\/+|\/+$/g, "");
  if (!trimmedPath) return null;

  const segments = trimmedPath.split("/");
  let currentPath = "/";

  const itemListElement = [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: new URL("/", siteBase).toString(),
    },
  ];

  for (const [index, segment] of segments.entries()) {
    currentPath += `${segment}/`;

    const isLast = index === segments.length - 1;
    const name = isLast
      ? title
      : (breadcrumbLabelMap[segment] ?? titleizeSegment(segment));

    itemListElement.push({
      "@type": "ListItem",
      position: index + 2,
      name,
      item: new URL(currentPath, siteBase).toString(),
    });
  }

  return {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement,
  };
}

const breadcrumbStructuredData = buildBreadcrumbStructuredData(Astro.url.pathname);
const headStructuredData = [
  ...(structuredData
    ? Array.isArray(structuredData)
      ? structuredData
      : [structuredData]
    : []),
  ...(breadcrumbStructuredData ? [breadcrumbStructuredData] : []),
];

const extendedMeta = [
  ...(keywords ? [{ name: "keywords", content: keywords }] : []),
  ...(imageAlt
    ? [
        { property: "og:image:alt", content: imageAlt },
        { name: "twitter:image:alt", content: imageAlt },
      ]
    : []),
];
---

<!doctype html>
<html lang={lang} class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicons/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="96x96"
      href="/favicons/favicon-96x96.png"
    />
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
    <link rel="shortcut icon" href="/favicons/favicon.ico" />
    <link rel="manifest" href="/favicons/site.webmanifest" />
    <meta name="apple-mobile-web-app-title" content="Unleft" />
    <meta name="theme-color" content="#7C3AED" />

    <SEO
      title={fullTitle}
      description={description}
      canonical={canonicalURL}
      noindex={noindex}
      nofollow={nofollow}
      openGraph={{
        basic: {
          title: fullTitle,
          type: ogType,
          image: ogImageURL,
          url: canonicalURL,
        },
        optional: {
          siteName: "Unleft",
          locale: locale,
          description: description,
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: "@UnleftStudio",
        creator: "@UnleftStudio",
        title: fullTitle,
        description: description,
        image: ogImageURL,
      }}
      extend={{
        meta: extendedMeta,
      }}
    />
    {
      headStructuredData.map((schema) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(schema)}
        />
      ))
    }

    <!-- Fonts are now self-hosted via @fontsource -->

    <!-- Astro View Transitions: persists header, background, and cookie banner across navigations -->
    <ClientRouter />
  </head>
  <body>
    {
      showSplash && (
        <>
          <!-- FOUC prevention: Immediately cover screen if no session storage flag -->
          <script>
            if (!sessionStorage.getItem("Unleft-splash-seen")) {
              const blocker = document.createElement("div");
              blocker.id = "splash-blocker";
              blocker.style.cssText =
                "position:fixed;inset:0;background-color:#050507;z-index:99;";
              document.body.insertBefore(blocker, document.body.firstChild);
              window.addEventListener("load", () => {
                const el = document.getElementById("splash-blocker");
                if (el) el.style.display = "none";
              });
            }
          </script>
          <SplashScreen client:load />
        </>
      )
    }
    <EtheralShadow client:idle transition:persist="etheral-shadow" />
    <slot />
    <CookieBanner client:idle transition:persist="cookie-banner" />
  </body>
</html>
