---
import '@/styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import CookieBanner from '@/components/layout/CookieBanner';
import { EtheralShadow } from '@/components/ui/EtheralShadow';
import { SplashScreen } from '@/components/ui/SplashScreen';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Engineering the Future. Beyond Software.',
  image = '/og-image.png',
} = Astro.props;

const siteBase = Astro.site ?? new URL('https://Unleft');
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const ogImageURL = new URL(image, siteBase);
const fullTitle = `${title} | Unleft`;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicons/favicon-96x96.png" />
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
    <link rel="shortcut icon" href="/favicons/favicon.ico" />
    <link rel="manifest" href="/favicons/site.webmanifest" />
    <meta name="apple-mobile-web-app-title" content="Unleft" />
    <meta name="theme-color" content="#7C3AED" />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#7C3AED" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Unleft" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-blocking async font load — avoids render-blocking while preserving swap -->
    <link
      href="https://fonts.googleapis.com/css2?family=Bruno+Ace+SC&family=Libre+Barcode+39+Extended+Text&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Bruno+Ace+SC&family=Libre+Barcode+39+Extended+Text&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Astro View Transitions: persists header, background, and cookie banner across navigations -->
    <ViewTransitions />
  </head>
  <body>
    <!-- FOUC prevention: Immediately cover screen if no session storage flag -->
    <script>
      if (!sessionStorage.getItem("Unleft-splash-seen")) {
        document.write('<div id="splash-blocker" style="position:fixed;inset:0;background-color:hsl(var(--background));z-index:99;"></div>');
        window.addEventListener('load', () => {
          const blocker = document.getElementById('splash-blocker');
          if (blocker) blocker.style.display = 'none';
        });
      }
    </script>
    <SplashScreen client:load transition:persist="splash" />
    <EtheralShadow client:idle transition:persist="etheral-shadow" />
    <slot />
    <CookieBanner client:idle transition:persist="cookie-banner" />
  </body>
</html>
