---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import CookieBanner from "@/components/layout/CookieBanner";
import { EtheralShadow } from "@/components/ui/EtheralShadow";
import { SplashScreen } from "@/components/ui/SplashScreen";

// @fontsource imports - Localized fonts
import "@fontsource/bruno-ace-sc/index.css";
import "@fontsource/gupter/400.css";
import "@fontsource/gupter/700.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/jetbrains-mono/400.css";

import { SEO } from "astro-seo";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  nofollow?: boolean;
}

const {
  title,
  description = "Engineering the Future. Beyond Software.",
  image = "/assets/images/og-image.png",
  noindex = false,
  nofollow = false,
} = Astro.props;

const siteBase = Astro.site ?? new URL("https://unleft.space");
const canonicalURL = new URL(Astro.url.pathname, siteBase).toString();
const ogImageURL = new URL(image, siteBase).toString();
const fullTitle = `${title} | Unleft`;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicons/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="96x96"
      href="/favicons/favicon-96x96.png"
    />
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
    <link rel="shortcut icon" href="/favicons/favicon.ico" />
    <link rel="manifest" href="/favicons/site.webmanifest" />
    <meta name="apple-mobile-web-app-title" content="Unleft" />
    <meta name="theme-color" content="#7C3AED" />

    <SEO
      title={fullTitle}
      description={description}
      canonical={canonicalURL}
      noindex={noindex}
      nofollow={nofollow}
      openGraph={{
        basic: {
          title: fullTitle,
          type: "website",
          image: ogImageURL,
          url: canonicalURL,
        },
        optional: {
          siteName: "Unleft",
          locale: "en_US",
          description: description,
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: "@UnleftStudio",
        creator: "@UnleftStudio",
        title: fullTitle,
        description: description,
        image: ogImageURL,
      }}
      extend={{
        meta: [
          { name: "theme-color", content: "#7C3AED" },
          { name: "viewport", content: "width=device-width, initial-scale=1" },
        ],
      }}
    />

    <!-- Fonts are now self-hosted via @fontsource -->

    <!-- Astro View Transitions: persists header, background, and cookie banner across navigations -->
    <ClientRouter />
  </head>
  <body>
    <!-- FOUC prevention: Immediately cover screen if no session storage flag -->
    <script>
      if (!sessionStorage.getItem("Unleft-splash-seen")) {
        const blocker = document.createElement("div");
        blocker.id = "splash-blocker";
        blocker.style.cssText = "position:fixed;inset:0;background-color:#050507;z-index:99;";
        document.body.insertBefore(blocker, document.body.firstChild);
        window.addEventListener("load", () => {
          const el = document.getElementById("splash-blocker");
          if (el) el.style.display = "none";
        });
      }
    </script>
    <SplashScreen client:load transition:persist="splash" />
    <EtheralShadow client:idle transition:persist="etheral-shadow" />
    <slot />
    <CookieBanner client:idle transition:persist="cookie-banner" />
  </body>
</html>
