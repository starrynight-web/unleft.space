---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header';
import Footer from '@/components/layout/Footer';
import BrandReveal from '@/components/layout/BrandReveal.astro';
import { EtheralShadow } from '@/components/ui/EtheralShadow';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  imageAlt?: string;
  ogType?: "website" | "article";
  locale?: string;
  lang?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  nofollow?: boolean;
}

const {
  title,
  description,
  keywords,
  image,
  imageAlt,
  ogType,
  locale,
  lang,
  structuredData,
  noindex,
  nofollow,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
  imageAlt={imageAlt}
  ogType={ogType}
  locale={locale}
  lang={lang}
  structuredData={structuredData}
  noindex={noindex}
  nofollow={nofollow}
>
  <Header client:load transition:persist="site-header" />
  
  <div 
    id="scroll-container" 
    class="relative z-20 bg-background transition-all duration-100 ease-out"
    style="clip-path: inset(0);"
  >
    <div class="relative z-30">
      <main class="pt-20 min-h-screen">
        <slot />
      </main>
      <Footer client:visible />
    </div>
    {/* Restoring fixed behavior but scoped/clipped by the parent container */}
    <EtheralShadow client:idle transition:persist="etheral-shadow" zIndex={1} position="fixed" />
  </div>

  <BrandReveal />

  <script>
    function updateRevealSpace() {
      const fixedBrand = document.getElementById('fixed-brand');
      const scrollContainer = document.getElementById('scroll-container');
      
      if (fixedBrand && scrollContainer) {
        const brandHeight = fixedBrand.offsetHeight;
        scrollContainer.style.marginBottom = `${brandHeight}px`;
      }
    }

    // Run on initial load and resize
    window.addEventListener('load', updateRevealSpace);
    window.addEventListener('resize', updateRevealSpace);
    
    // Also run after Astro page transitions
    document.addEventListener('astro:page-load', updateRevealSpace);
  </script>
</BaseLayout>
