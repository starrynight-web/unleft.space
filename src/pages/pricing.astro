---
import PageLayout from '@/layouts/PageLayout.astro';
import { HoverButton } from '@/components/ui/hover-button';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Check, ArrowRight } from 'lucide-react';
import { availablePlans } from '@/lib/plans';

type Tier = typeof availablePlans[0] & {
  cta: string;
  highlighted: boolean;
};

const tiers: Tier[] = [
  {
    ...availablePlans[0],
    cta: 'Get Started',
    highlighted: false,
  },
  {
    ...availablePlans[1],
    cta: 'Get Started',
    highlighted: true,
  },
  {
    ...availablePlans[2],
    cta: 'Contact Us',
    highlighted: false,
  },
];
---

<PageLayout title="Pricing" description="Transparent pricing for every scale of business.">
  <section class="w-full px-4 md:px-12 py-24 text-center overflow-hidden relative">
     {/* Ambient background effects */}
     <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-5xl bg-accent-primary/5 rounded-full blur-[120px] pointer-events-none -z-10"></div>
     
    <Badge className="mb-6 bg-accent-primary/10 text-accent-glow border-none mx-auto w-fit font-gupter">Transparent Pricing</Badge>
    <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-8 tracking-tighter">
      Simple, <span class="text-accent-primary">Honest</span> Plans.
    </h1>
    <p class="text-xl text-text-secondary leading-relaxed mb-12 max-w-2xl mx-auto">
      Choose a plan that fits your goals. Custom software and game projects are quoted individually.
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-6 pb-24">
    <div class="grid md:grid-cols-3 gap-8 items-stretch">
      {tiers.map((tier) => (
        <Card className={`border-[#2D2D44] bg-[#1A1A2E]/50 flex flex-col relative overflow-hidden transition-all duration-500 hover:shadow-2xl ${tier.highlighted ? 'border-accent-primary shadow-[0_0_40px_rgba(124,58,237,0.1)] scale-[1.02] z-10' : 'hover:border-accent-glow/30 hover:-translate-y-1'}`}>          
          <CardHeader className="pb-4 relative">
            {tier.highlighted && (
                <Badge className="w-fit mb-4 bg-accent-primary/20 text-accent-glow border-none animate-pulse">Most Popular</Badge>
            )}
            <CardTitle className="text-2xl text-text-primary mb-2">{tier.name}</CardTitle>
            <CardDescription className="text-text-secondary leading-relaxed">{tier.description}</CardDescription>
          </CardHeader>

          <CardContent className="flex flex-col flex-1 mt-auto">
            <div class="mb-10 p-6 rounded-2xl bg-[#0A0A0F]/50 border border-[#2D2D44]/30">
              <span class="text-4xl font-bold text-text-primary tracking-tight">{tier.price}</span>
              {!tier.price.includes('+') && <span class="text-text-secondary ml-1.5 text-sm uppercase tracking-widest">/ project</span>}
            </div>

            <ul class="space-y-4 mb-10 flex-1">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm text-text-secondary group/item">
                  <div class="mt-0.5 rounded-full p-0.5 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 group-hover/item:bg-emerald-500/20 transition-colors">
                    <Check className="h-3 w-3" />
                  </div>
                  <span class="group-hover/item:text-text-primary transition-colors">{feature}</span>
                </li>
              ))}
            </ul>

            <HoverButton
              href={`/checkout?plan=${tier.name.toLowerCase()}`}
              client:load
              className={`w-full h-14 rounded-2xl transition-all ${
                tier.highlighted
                  ? '[--circle-start:#C084FC] [--circle-end:#7B2CBF] bg-[#7B2CBF]/10 text-white border border-[#C084FC]/30 hover:bg-[#7B2CBF]/20'
                  : 'text-text-primary border border-[#2D2D44] hover:bg-[#1A1A2E] hover:border-[#C084FC]/20'
              }`}
            >
              <span class="font-bold tracking-wide">{tier.cta}</span>
              <ArrowRight className="h-4 w-4 transition-transform group-hover:translate-x-1" />
            </HoverButton>
          </CardContent>
        </Card>
      ))}
    </div>

    <div class="mt-24 text-center p-12 rounded-3xl border border-[#2D2D44]/30 bg-linear-to-b from-transparent to-[#1A1A2E]/20">
      <p class="text-text-secondary mb-8 max-w-xl mx-auto text-lg leading-relaxed">
        Need a custom quote for complex <span class="text-text-primary font-medium">game development</span>, <span class="text-text-primary font-medium">AI systems</span>, or large-scale <span class="text-text-primary font-medium">custom software</span>?
      </p>
      
      <HoverButton
        href="/contact?mode=custom"
        client:load
        className="mx-auto rounded-full h-14 px-10 border border-accent-glow/20 bg-[#1A1A2E]/30 text-text-primary hover:border-accent-glow/40"
      >
        <span class="font-bold tracking-wide">Request a Custom Quote</span>
        <ArrowRight className="h-4 w-4" />
      </HoverButton>
    </div>
  </section>
</PageLayout>
