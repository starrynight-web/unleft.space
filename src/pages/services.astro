---
import PageLayout from '@/layouts/PageLayout.astro';
import ServicesBentoGrid from '@/components/sections/ServicesBentoGrid';
import { Badge } from '@/components/ui/badge';

const services = [
  {
    title: 'Business Websites',
    subtitle: 'High-performance, SEO-optimized',
    description: 'Lightning-fast, SEO-optimized websites built with Astro, React, and Next.js. We architect for Core Web Vitals from day one — every site targets >90 Lighthouse scores and sub-2s load times.',
    features: ['Astro + Next.js stack', 'SEO-first architecture', '>90 Lighthouse score', 'Edge-deployed globally'],
    color: '#3B82F6',
  },
  {
    title: 'Game Development',
    subtitle: 'Cross-platform immersive experiences',
    description: 'Cross-platform immersive experiences powered by Unity and C#. From casual mobile games to complex multiplayer systems with server-authoritative architecture, Photon networking, and professional post-processing pipelines.',
    features: ['Unity & C# expertise', 'Multiplayer with Photon', 'iOS, Android & PC', 'Post-processing & VFX'],
    color: '#7C3AED',
  },
  {
    title: 'Custom Software',
    subtitle: 'Scalable backends & APIs',
    description: 'Scalable backend systems, APIs, microservices, and internal tools tailored to your exact business logic. From event-driven microservices to monoliths — we choose the right shape for your scale.',
    features: ['REST & GraphQL APIs', 'Microservices & Docker', 'PostgreSQL & MongoDB', 'CI/CD pipelines'],
    color: '#10B981',
  },
  {
    title: 'AI-Based Systems',
    subtitle: 'Intelligent automation & ML',
    description: 'Intelligent automation, ML pipelines, and AI-powered features integrated directly into your products. We bridge the gap between AI research and production-grade deployment with reliable monitoring and fallbacks.',
    features: ['LLM integration (OpenAI, Gemini)', 'LangChain pipelines', 'Python ML backends', 'Usage monitoring & guardrails'],
    color: '#F59E0B',
  },
  {
    title: 'Mobile Applications',
    subtitle: 'iOS & Android cross-platform',
    description: 'Cross-platform mobile apps with React Native and Expo for consistent experiences on iOS and Android. Native feel without native cost — push notifications, biometrics, camera access, and App Store deployment all handled.',
    features: ['React Native + Expo', 'Firebase backend', 'Push notifications', 'App Store & Play Store launch'],
    color: '#06B6D4',
  },
];
---

<PageLayout
  title="Services"
  description="Explore Unleft services across custom websites, software platforms, AI systems, mobile apps, and cross-platform game development."
  keywords="software development services, web development services, AI development services, mobile app development, game development services, custom software company"
  imageAlt="Unleft services page preview highlighting web, AI, mobile, and game development services"
>
  <section class="w-full px-4 md:px-12 py-24 text-center">
    <Badge className="mb-6 bg-accent-primary/10 text-accent-glow border-none mx-auto w-fit font-gupter">Our Capabilities</Badge>
    <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-8 tracking-tighter">
      End-to-End <span class="text-accent-primary">Excellence</span>.
    </h1>
    <p class="text-xl text-text-secondary leading-relaxed mb-12 max-w-2xl mx-auto">
      From enterprise platforms to gaming cross-platform experiences. We build what others can't — bringing precision engineering to creative digital solutions.
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-6 pb-24">
    <ServicesBentoGrid client:visible services={services} />
  </section>
</PageLayout>
