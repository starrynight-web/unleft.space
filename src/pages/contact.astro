---
import PageLayout from '@/layouts/PageLayout.astro';
import ContactForm from '@/components/sections/ContactForm';
import { ContactCard } from '@/components/ui/contact-card';
import { Badge } from '@/components/ui/badge';
import { Mail, MapPin, Github, Linkedin } from 'lucide-react';
---

<PageLayout title="Contact" description="Contact Unleft — a software development studio based in Dhaka, Bangladesh. Reach out to start your web, game, AI, or mobile project.">
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="text-center mb-16 px-4">
      <Badge className="mb-6 bg-accent-primary/10 text-accent-glow border-none mx-auto w-fit font-gupter">Get In Touch</Badge>
      <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-8 tracking-tighter">
        LET'S <span class="text-accent-primary">BUILD</span>
      </h1>
      <p class="text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto">
        Ready to turn your vision into high-performance digital reality? Drop us a message or find us on social.
      </p>
    </div>

    <ContactCard 
      title="Contact Info"
      description="Find us on social media or reach out via email."
      contactInfo={[
        { icon: Mail, label: 'Email', value: 'hello@unleft.space', href: 'mailto:hello@unleft.space' },
        { icon: MapPin, label: 'Location', value: 'Dhaka, Bangladesh' },
        { icon: Github, label: 'GitHub', value: 'github.com/Unleft', href: 'https://github.com/Unleft' },
        { icon: Linkedin, label: 'LinkedIn', value: 'linkedin.com/company/Unleft', href: 'https://linkedin.com/company/Unleft' }
      ]}
    >
      <div class="w-full">
        <h2 class="text-2xl font-bold text-text-primary mb-8">Send a Message</h2>
        <ContactForm client:load />
      </div>
    </ContactCard>
  </section>
</PageLayout>
