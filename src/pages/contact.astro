---
import PageLayout from '@/layouts/PageLayout.astro';
import ContactForm from '@/components/sections/ContactForm';
import { ContactCard } from '@/components/ui/contact-card';
import { Mail, MapPin, Github, Linkedin } from 'lucide-react';
---

<PageLayout title="Contact" description="Get in touch with Unleft. Let's build something extraordinary.">
  <section class="max-w-7xl mx-auto px-6 py-24">
    <ContactCard 
      title="LET'S BUILD"
      description="Ready to turn your vision into high-performance digital reality? Drop us a message or find us on social."
      contactInfo={[
        { icon: Mail, label: 'Email', value: 'hello@Unleft.space' },
        { icon: MapPin, label: 'Location', value: 'Dhaka, Bangladesh' }
      ]}
    >
      <div class="w-full">
        <h2 class="text-2xl font-bold text-text-primary mb-8">Send a Message</h2>
        <ContactForm client:load />
      </div>
    </ContactCard>

    <!-- Social Links (Optional, if they don't fit in ContactCard yet) -->
    <div class="flex gap-4 pt-12 justify-start">
        <a href="https://github.com/Unleft" target="_blank" rel="noopener noreferrer" class="h-12 w-12 rounded-xl border border-[#2D2D44] flex items-center justify-center hover:bg-[#1A1A2E] hover:border-accent-glow/30 transition-all group">
            <Github className="h-6 w-6 text-text-secondary group-hover:text-accent-glow transition-colors" />
        </a>
        <a href="https://linkedin.com/company/Unleft" target="_blank" rel="noopener noreferrer" class="h-12 w-12 rounded-xl border border-[#2D2D44] flex items-center justify-center hover:bg-[#1A1A2E] hover:border-accent-glow/30 transition-all group">
            <Linkedin className="h-6 w-6 text-text-secondary group-hover:text-accent-glow transition-colors" />
        </a>
    </div>
  </section>
</PageLayout>
