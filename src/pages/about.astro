---
import PageLayout from "@/layouts/PageLayout.astro";
import CTASection from "@/components/sections/CTASection.astro";
import { Badge } from "@/components/ui/badge";
import { LogoCloud } from "@/components/ui/logo-cloud-2";
import { cn } from "@/lib/utils";
import {
  Rocket,
  Target,
  Globe,
  Heart,
  Github,
  ExternalLink,
} from "lucide-react";

const values = [
  {
    icon: Rocket,
    title: "Innovation",
    desc: "We push boundaries — from AI-powered systems to WebGL-rendered game worlds.",
  },
  {
    icon: Target,
    title: "Performance",
    desc: "Zero compromise on speed. Every project targets >90 Lighthouse scores.",
  },
  {
    icon: Globe,
    title: "Scalability",
    desc: "Architecture that grows with you, from MVP to enterprise-grade scale.",
  },
  {
    icon: Heart,
    title: "Reliability",
    desc: "Clean code, rigorous testing, and ongoing support you can count on.",
  },
];

const roadmap = [
  {
    year: "Year 1",
    label: "Service Provider",
    desc: "Business websites, custom software, and early game prototypes.",
    active: true,
  },
  {
    year: "Year 2",
    label: "Game Studio + SaaS",
    desc: "Unity game releases, first SaaS product, and international clients.",
  },
  {
    year: "Year 3",
    label: "Global Brand",
    desc: "Published games, multiple SaaS products, and a global engineering presence.",
  },
];
const team = [
  {
    name: "Golam Rasul",
    role: "Chairperson",
    desc: "Leads Board, ensures vision & compliance.",
    image: "/images/rasul1.webp",
    skills: ["Python", "HTML", "Ruby"],
    github: "https://github.com/rasul",
    portfolio: "https://rasul.me",
  },
  {
    name: "Golam Morshed Eashan",
    role: "Executive Controlling Officer",
    desc: "Controls operation, decision maker.",
    image: "/images/eashan.webp",
    skills: ["Next.Js", "Tailwind CSS", "Python", "Django", "C#"],
    github: "https://github.com/eashan",
    portfolio: "https://eashan.portfolio",
  },
  {
    name: "Sayma Ferdousi Fariha",
    role: "Managing Director",
    desc: "Aligns with investors & stakeholders.",
    image: "/images/sayma.webp",
    skills: ["HTML", "CSS", "Python", "Django"],
    github: "https://github.com/sayma",
    portfolio: "https://sayma.me",
  },
  {
    name: "Mahtabul Al Nahian",
    role: "Chief Operating Officer",
    desc: "Manages internal operations.",
    image: "/images/mahtab.webp",
    skills: ["Next.Js", "Astro", "Tailwind CSS", "JavaScript", "Figma"],
    github: "https://github.com/mahtab",
    portfolio: "https://mahtab.me",
  },
  {
    name: "Nabila Rahman Rodela",
    role: "Chief Marketing Officer",
    desc: "Leads marketing and branding.",
    image: "/images/rodela.webp",
    skills: ["HTML", "CSS", "SQL", "SEO"],
    github: "https://github.com/rodela",
    portfolio: "https://rodela.me",
  },
  {
    name: "Tafrim Ahmed",
    role: "Chief Logic Operator",
    desc: "Ensures reliability with robust programming.",
    image: "/images/tafrim.webp",
    skills: ["HTML", "CSS", "JavaScript", "TensorFlow"],
    github: "https://github.com/tafrim",
    portfolio: "https://tafrim.me",
  },
];
---

<PageLayout
  title="About Us"
  description="Unleft is a performance-driven software company based in Dhaka, Bangladesh, combining game studio creativity with enterprise engineering precision."
>
  <section class="w-full px-4 md:px-12 py-24 text-center">
    <Badge
      className="mb-6 bg-accent-primary/10 text-accent-glow border-none mx-auto w-fit font-gupter"
      >About Unleft</Badge
    >
    <h1
      class="text-4xl md:text-6xl font-bold text-text-primary mb-8 tracking-tighter"
    >
      Beyond <span class="text-accent-primary">Software</span>.
    </h1>
    <p
      class="text-xl text-text-secondary leading-relaxed mb-12 max-w-2xl mx-auto"
    >
      Unleft is a futuristic, performance-driven software solutions company. We
      combine the creativity of a game studio with the precision of enterprise
      engineering.
    </p>

    <div class="max-w-4xl mx-auto">
      <div class="relative group">
        <div
          class="absolute -inset-4 bg-gradient-to-r from-accent-primary/10 to-accent-secondary/10 rounded-3xl blur-2xl transition-opacity group-hover:opacity-100 opacity-70"
        >
        </div>
        <div
          class="relative rounded-2xl border border-[#2D2D44] bg-[#0A0A0F]/60 p-8 md:p-12 backdrop-blur-sm"
        >
          <blockquote
            class="text-2xl font-heading font-bold text-text-primary leading-tight italic"
          >
            "We engineer digital experiences that push the boundaries of what's
            possible — combining gaming aesthetics with enterprise-grade
            performance."
          </blockquote>
          <p
            class="mt-6 text-sm text-accent-glow font-mono uppercase tracking-[0.2em]"
          >
            — Our Promise
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-24 max-w-7xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-text-primary mb-12 text-center">
      Our Leadership
    </h2>
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 -space-x-px -space-y-px border-[#2D2D44] border-[0.5px]"
    >
      {
        team.map((member, index) => {
          const isLeader = member.name === "Golam Rasul";
          // Logic to fill rows:
          // Index 0: spans 6 (Row 1)
          // Index 1, 2, 3: span 2 each (Row 2 fills 6)
          // Index 4, 5: span 3 each (Row 3 fills 6)
          let colSpan = "lg:col-span-2";
          if (isLeader) colSpan = "lg:col-span-6 md:col-span-2";
          else if (index >= 4) colSpan = "lg:col-span-3";

          return (
            <div
              class={cn(
                "group relative p-8 border-[#2D2D44] border-[0.5px] bg-[#0A0A0F]/70 transition-all duration-500 hover:bg-[#0D0D14] hover:z-10 overflow-hidden",
                colSpan,
              )}
            >
              {/* Ambient Glow */}
              <div class="absolute -inset-4 bg-accent-primary/5 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700" />

              <div
                class={`relative z-10 flex ${isLeader ? "md:flex-row flex-col items-start gap-8" : "flex-col items-start"}`}
              >
                <div class="shrink-0">
                  <img
                    src={member.image}
                    alt={member.name}
                    class={`${isLeader ? "w-32 h-32" : "w-20 h-20"} rounded-2xl object-cover border-2 border-accent-primary/30 p-1 bg-[#0A0A0F] group-hover:scale-105 transition-transform duration-500`}
                  />
                </div>
                <div class="flex-grow">
                  <div class="flex items-center gap-3">
                    <h3
                      class={`font-bold text-text-primary ${isLeader ? "text-2xl md:text-3xl" : "text-lg"} group-hover:text-accent-glow transition-colors`}
                    >
                      {member.name}
                    </h3>
                    {isLeader && (
                      <Badge className="bg-accent-primary/20 text-accent-glow border-accent-primary/30 h-fit">
                        Chairperson
                      </Badge>
                    )}
                  </div>
                  <p class="text-accent-glow text-xs font-mono uppercase tracking-wider mt-1">
                    {member.role}
                  </p>
                  <p
                    class={`mt-4 text-text-secondary leading-relaxed ${isLeader ? "text-base max-w-2xl" : "text-sm"}`}
                  >
                    {member.desc}
                  </p>

                  <div class="mt-4 flex flex-wrap items-center gap-4">
                    {member.github && (
                      <a
                        href={member.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center gap-1.5 text-xs text-text-secondary hover:text-accent-glow transition-colors"
                        title="GitHub Profile"
                      >
                        <Github size={15} />
                        <span>View Profile</span>
                      </a>
                    )}
                    {member.portfolio && (
                      <a
                        href={member.portfolio}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center gap-1.5 text-xs text-text-secondary hover:text-accent-glow transition-colors"
                        title="Portfolio Website"
                      >
                        <ExternalLink size={15} />
                        <span>View Portfolio</span>
                      </a>
                    )}
                  </div>

                  <div class="mt-6 flex flex-wrap gap-2">
                    {member.skills.map((skill) => (
                      <span class="text-[10px] font-mono px-2 py-1 rounded bg-accent-primary/10 text-accent-glow border border-accent-primary/20">
                        {skill}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- Core Values -->
  <section class="bg-[#1A1A2E]/30 py-24">
    <div class="mx-auto max-w-7xl px-6">
      <h2 class="text-3xl font-bold text-text-primary mb-12 text-center">
        Core Values
      </h2>
      <LogoCloud
        items={values.map((v) => ({
          icon: v.icon,
          title: v.title,
          description: v.desc,
        }))}
      />
    </div>
  </section>

  <!-- Roadmap -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <h2 class="text-3xl font-bold text-text-primary mb-12 text-center">
      Our 3-Year Arc
    </h2>
    <div class="relative">
      <div
        class="absolute left-8 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-accent-primary via-accent-glow/30 to-transparent"
      >
      </div>
      <div class="space-y-12">
        {
          roadmap.map((phase, i) => (
            <div
              class={`relative flex flex-col md:flex-row items-start gap-8 ${i % 2 === 1 ? "md:flex-row-reverse" : ""}`}
            >
              <div class="flex-1" />
              <div class="relative z-10 flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-full border-2 border-accent-primary bg-[#0A0A0F]">
                <span
                  class={`text-xs font-mono font-bold ${phase.active ? "text-accent-glow" : "text-text-secondary"}`}
                >
                  {phase.year}
                </span>
              </div>
              <div class="flex-1">
                <div
                  class={`rounded-xl border p-6 ${phase.active ? "border-accent-primary bg-accent-primary/5" : "border-[#2D2D44] bg-[#1A1A2E]/30"}`}
                >
                  <h3 class="font-bold text-text-primary mb-2">
                    {phase.label}
                  </h3>
                  <p class="text-sm text-text-secondary">{phase.desc}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection />
</PageLayout>
